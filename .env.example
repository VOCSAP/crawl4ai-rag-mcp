# ========================================
# MCP CRAWL4AI SERVER -- LOCAL DEPLOYMENT
# ========================================

# Transport (sse required for remote access from Claude Code)
TRANSPORT=sse
HOST=0.0.0.0
PORT=8051

# ========================================
# DATABASE -- pgvector local (Docker)
# ========================================

DATABASE_URL=postgresql://rag:rag@postgres:5432/ragdb
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=ragdb

# ========================================
# OLLAMA -- embedding + LLM (external)
# ========================================

# Base URL of your Ollama instance (no trailing slash, no /v1)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Embedding model installed on Ollama
EMBEDDING_MODEL=nomic-embed-text:v1.5

# Dimension produced by the embedding model above
# nomic-embed-text:v1.5 = 768 | mxbai-embed-large = 1024
EMBEDDING_DIMENSIONS=768

# Placeholder required by the openai client (points to Ollama, not OpenAI)
OPENAI_API_KEY=ollama

# LLM for contextual embeddings and summaries -- leave empty to disable
# When set, must be a model available on the same Ollama instance (e.g. qwen3.5:4b)
MODEL_CHOICE=

# Reranking model -- interpretation depends on RERANKING_BACKEND:
#   local  -> HuggingFace cross-encoder name (default: cross-encoder/ms-marco-MiniLM-L-6-v2)
#   remote -> Ollama model name (default: MODEL_CHOICE or qwen3.5:4b)
RERANKING_MODEL=

# ========================================
# SEARXNG (internal Docker network)
# ========================================

SEARXNG_URL=http://searxng:8080
SEARXNG_HOSTNAME=localhost
SEARXNG_TLS=internal
SEARXNG_USER_AGENT=MCP-Crawl4AI-RAG-Server/1.0
SEARXNG_DEFAULT_ENGINES=google,bing,duckduckgo
SEARXNG_TIMEOUT=30

# ========================================
# RAG FEATURES
# ========================================

# Enhance chunks with LLM-generated context (requires MODEL_CHOICE)
USE_CONTEXTUAL_EMBEDDINGS=false

# Combine vector + keyword search for better recall
USE_HYBRID_SEARCH=true

# Extract and index code examples separately (requires USE_AGENTIC_RAG=true)
USE_AGENTIC_RAG=false

# Rerank results after vector/hybrid search to improve relevance ordering
USE_RERANKING=false

# Reranking backend: "local" (CPU CrossEncoder, original behavior) or "remote" (Ollama LLM via RankGPT)
RERANKING_BACKEND=local

# Timeout in seconds for reranking calls (remote: model load + inference can exceed 30s)
RERANKING_TIMEOUT=60

# Timeout in seconds for all LLM calls (contextual embedding, summaries, reranking remote)
# Keep higher on CPU-backed Ollama (120+); 60s is safe for GPU-backed instances
LLM_TIMEOUT=60

# Max parallel LLM workers for contextual embedding generation (one call per chunk)
# Keep low (1-2) if Ollama handles one request at a time to avoid silent hangs
CONTEXTUAL_EMBEDDING_WORKERS=2

# Max chars of the full document sent as context for contextual embedding prompts
# qwen3.5:4b has a 4096 token context window; 8000 chars (~2000 tokens) leaves room for chunk + response
CONTEXTUAL_DOC_TRUNCATION=8000

# Neo4j knowledge graph for hallucination detection (hors scope)
USE_KNOWLEDGE_GRAPH=false

# ========================================
# NEO4J (only if USE_KNOWLEDGE_GRAPH=true)
# ========================================

# NEO4J_URI=bolt://neo4j:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password
